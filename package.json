{
  "name": "zalo-tg",
  "version": "1.0.0",
  "description": "Zalo ↔ Telegram bridge using Forum Topics",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0205 tsx src/index.ts",
    "dev:watch": "NODE_OPTIONS=--disable-warning=DEP0205 node --watch --import tsx src/index.ts",
    "build": "tsc",
    "start": "node --disable-warning=DEP0205 dist/index.js",
    "test": "NODE_OPTIONS=--disable-warning=DEP0205 tsx --test tests/**/*.test.ts",
    "check": "npm run build && npm test",
    "test:coverage": "node --disable-warning=DEP0205 --import tsx --test --experimental-test-coverage tests/**/*.test.ts",
    "security:audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.1",
    "adm-zip": "^0.5.17",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "image-size": "^2.0.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "simple-plist": "^1.3.1",
    "telegraf": "^4.16.3",
    "zca-js": "2.1.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/image-size": "^0.7.0",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.11"
  }
}
