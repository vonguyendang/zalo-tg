{
  "name": "zalo-tg",
  "version": "1.0.0",
  "description": "Zalo ↔ Telegram bridge using Forum Topics",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "tui:build": "go build -o bin/zalo-tg-tui ./cmd/zalo-tg-tui && GOBIN=$PWD/bin go install github.com/charmbracelet/glow@v1.5.1",
    "test": "NODE_OPTIONS=--disable-warning=DEP0205 tsx --test tests/*.test.ts",
    "check": "npm run build && npm test",
    "security:audit": "npm audit --omit=dev",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@types/qrcode": "^1.5.6",
    "adm-zip": "^0.5.17",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "https-proxy-agent": "^9.0.0",
    "image-size": "^2.0.2",
    "node-fetch": "^2.7.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "simple-plist": "^1.3.1",
    "socks-proxy-agent": "^10.0.0",
    "telegraf": "^4.16.3",
    "zca-js": "2.1.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/image-size": "^0.7.0",
    "@types/node": "^20.19.41",
    "@types/node-fetch": "^2.6.13",
    "@types/qrcode-terminal": "^0.12.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
