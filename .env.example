# ─── zalo-tg full environment example ────────────────────────────────────────
# Copy this file to .env, then fill in your real Telegram values.
# Lines starting with # are examples/documentation and are not active.

# ─── Required: Telegram bridge target ────────────────────────────────────────

# Telegram Bot Token — get it from @BotFather.
TG_TOKEN=1234567890:ABCDEFabcdef1234567890abcdefABCDEF123

# Telegram forum supergroup ID. It must be a negative safe integer.
# The bot must be an admin of this group, and Topics must be enabled.
TG_GROUP_ID=-1001234567890

# ─── Storage and Zalo session ────────────────────────────────────────────────

# Persistent data directory for topics, message maps, user cache, polls,
# auto-reply state and other local stores. Relative paths resolve from repo root.
DATA_DIR=./data

# Zalo credentials file written after QR login. Keep this private.
ZALO_CREDENTIALS_PATH=./credentials.json

# Optional root for temporary files shared with Telegram Local Bot API.
# Use this when bridge and telegram-bot-api run in different containers but
# must both see the same file:// paths.
# ZALO_TG_SHARED_TMP_ROOT=/tmp

# ─── Zalo behavior ───────────────────────────────────────────────────────────

# 1 = skip messages from muted Zalo groups completely.
# 0/unset = still mirror muted groups.
ZALO_SKIP_MUTED_GROUPS=0

# 1/unset = mirror Zalo "mute notifications" as silent Telegram messages.
# 0 = always notify on Telegram even if the Zalo thread is muted.
ZALO_MUTE_SILENT=1

# ─── Telegram Local Bot API ─────────────────────────────────────────────────
# Enables larger file handling through a local telegram-bot-api server.
# Official Telegram Bot API mode is used when LOCAL_BOT_API is 0/unset.

# 1 = send bot requests to TG_LOCAL_SERVER.
# 0/unset = use official api.telegram.org.
LOCAL_BOT_API=0

# Local Bot API HTTP endpoint. Required only when LOCAL_BOT_API=1.
# In Docker Compose this is overridden to http://telegram-bot-api:8081.
TG_LOCAL_SERVER=http://127.0.0.1:8081

# Docker Compose variables for the telegram-bot-api service.
# Get TG_API_ID and TG_API_HASH at https://my.telegram.org/apps.
TG_API_ID=
TG_API_HASH=
TG_LOCAL_PORT=8081

# Data directory used by start-local-api.sh when you run a locally installed
# telegram-bot-api binary instead of Docker Compose.
# TGBOTAPI_DATA_DIR=./data/bot-api

# ─── Runtime / updater supervision ──────────────────────────────────────────

# Set only when an external runner/supervisor restarts the process after exit
# code 42. Docker Compose already sets this for the zalo-tg service.
# Do not set this to 0; leave it commented unless you really run a supervisor.
# ZALO_TG_RUNNER=1

# Node runtime mode. Docker sets NODE_ENV=production automatically.
# NODE_ENV=production

# ─── Terminal UI / dashboard ────────────────────────────────────────────────

# 0 = disable the live dashboard/TUI and print normal logs.
# ZALO_TG_TUI=0

# ansi = force the legacy TypeScript ANSI dashboard even when the Go sidecar
# exists. Any other/unset value lets the app auto-use bin/zalo-tg-tui.
# ZALO_TG_TUI_ENGINE=ansi

# Mouse capture for the Go TUI.
# Enabled by default. Use 0/false/off/no/native to keep native terminal mouse.
# ZALO_TG_TUI_MOUSE=native

# Absolute or relative path to a custom TUI sidecar binary.
# ZALO_TG_TUI_BIN=./bin/zalo-tg-tui

# Absolute or relative path to a custom Glow renderer binary used by the Go TUI
# help pane. Defaults to a sibling glow binary beside the sidecar, then PATH.
# ZALO_TG_GLOW_BIN=./bin/glow

# 0 = do not dump the last TUI activity lines when the sidecar exits early.
# ZALO_TG_TUI_DUMP_ON_EXIT=0

# 1 = skip startup/shutdown terminal animations.
# ZALO_TG_NO_ANIMATION=1

# Standard no-color convention. Any value disables colored dashboard output.
# NO_COLOR=1

# Terminal type. Normally set by your shell/terminal; TERM=dumb disables the
# interactive dashboard.
# TERM=dumb

# Internal marker set automatically when Node spawns the Go TUI sidecar.
# Do not set manually.
# ZALO_TG_TUI_SIDECAR=1

# ─── Installer-only variables ───────────────────────────────────────────────
# These are read by install.sh from the shell environment, not by the running
# bridge. Export them before running the curl installer if needed.

# ZALO_TG_INSTALL_DIR=$HOME/zalo-tg
# ZALO_TG_REPO=https://github.com/williamcachamwri/zalo-tg.git
