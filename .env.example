# ─── Bắt buộc ────────────────────────────────────────────────────────────────

# Telegram Bot Token — lấy từ @BotFather (https://t.me/BotFather)
TG_TOKEN=1234567890:ABCDEFabcdef1234567890abcdefABCDEF123

# Telegram Forum Group ID (số âm, ví dụ: -1001234567890)
# Bot phải là admin của group này, group phải bật chế độ Topics (Supergroup)
TG_GROUP_ID=-1001234567890

# ─── Tuỳ chọn ────────────────────────────────────────────────────────────────

# Đường dẫn tới file credentials Zalo (mặc định: ./credentials.json)
# ZALO_CREDENTIALS_PATH=./credentials.json

# Thư mục lưu dữ liệu persistent: msg-map, topics map, ... (mặc định: ./data)
# DATA_DIR=./data

# Bỏ qua tin nhắn từ nhóm Zalo đã tắt thông báo (mặc định: false)
# ZALO_SKIP_MUTED_GROUPS=0

# ─── Đồng bộ lịch sử tin nhắn (tuỳ chọn) ────────────────────────────────────

# Số tin nhắn lịch sử tối đa mỗi lần sync (dùng lệnh /history hoặc auto-sync)
# Giá trị 0 sẽ tắt tính năng. Zalo thường cho phép max 500-1000 tin 1 lần. Mặc định: 1000
# ZALO_HISTORY_SYNC_COUNT=1000

# Delay (milliseconds) giữa mỗi tin khi sync lịch sử (để tránh bị Zalo/Telegram ban)
# Giá trị an toàn nhất là 3000 (3s) để chạy "thụ động" dưới background. Mặc định: 3000
# ZALO_HISTORY_SYNC_DELAY_MS=3000

# Tự động đồng bộ lịch sử khi tạo topic nhóm mới lần đầu (mặc định: false)
# Bật: 1 | Tắt: 0
# ZALO_HISTORY_AUTO_SYNC=0

# ─── Local Bot API Server (tuỳ chọn) ────────────────────────────────────────
# Tăng giới hạn file lên 2 GB (mặc định official API: 20 MB upload / 50 MB download)
#
# Hướng dẫn đầy đủ: xem LOCAL_BOT_API_SETUP.md
#
# Bật/tắt local Bot API:
#   1 = dùng local server tại TG_LOCAL_SERVER (cần cài telegram-bot-api binary)
#   0 = dùng official api.telegram.org (không cần cài gì thêm)
LOCAL_BOT_API=0

# Lấy TG_API_ID và TG_API_HASH tại: https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# URL của local Bot API server (chỉ dùng khi LOCAL_BOT_API=1)
TG_LOCAL_SERVER=http://localhost:8081
